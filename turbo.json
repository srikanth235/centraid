{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "native/*.node",
        // blueprints vendor-browser-shared + vendor-pdfjs (gitignored kit bits)
        "kit/blob-format.js",
        "kit/video-frame.js",
        "kit/pdf.min.mjs",
        "kit/pdf.worker.min.mjs",
        // web iroh wasm ensure path when rebuilt on CI
        "src/generated/centraid_web_iroh_bg.wasm"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    }
  }
}
