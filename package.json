{
  "name": "centraid-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Centraid — personal app builder. Monorepo containing desktop (Electron), mobile (Expo), and shared design tokens.",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "typescript": "^5.6.0"
    }
  },
  "scripts": {
    "reload-plugin": "scripts/reload-plugin.sh",
    "dev:desktop": "turbo run dev --filter=@centraid/desktop",
    "dev:mobile": "turbo run dev --filter=@centraid/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:types": "bash scripts/lint-types.sh",
    "check": "bun run format:check && bun run lint",
    "fix": "ultracite fix",
    "ci": "bun run check && bun run typecheck && bun run lint:types",
    "docs:build": "node scripts/docs-site/build.mjs",
    "docs:serve": "python3 -m http.server 4173 --bind 127.0.0.1 -d dist/docs-site",
    "docs:smoke": "node scripts/docs-site/smoke.mjs",
    "docs:deploy:dry": "wrangler deploy --config wrangler.docs.toml --dry-run --outdir .wrangler/docs-dry",
    "docs:deploy": "wrangler deploy --config wrangler.docs.toml"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "jsdom": "26.1.0",
    "oxfmt": "^0.43.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "ultracite": "7.4.0",
    "vitest": "3.2.4",
    "wrangler": "^3.90.0"
  },
  "packageManager": "bun@1.3.13"
}
