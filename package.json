{
  "name": "centraid-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Centraid — personal app builder. Monorepo containing desktop (Electron), mobile (Expo), and shared design tokens.",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "typescript": "^5.6.0"
    }
  },
  "scripts": {
    "reload-plugin": "scripts/reload-plugin.sh",
    "dev:desktop": "turbo run dev --filter=@centraid/desktop",
    "dev:mobile": "turbo run dev --filter=@centraid/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "check": "bun run format:check && bun run lint",
    "fix": "ultracite fix",
    "ci": "bun run check && bun run typecheck",
    "docs:build": "node scripts/docs-site/build.mjs && node scripts/docs-site/source-index.mjs && pagefind --site dist/docs-site --output-path dist/docs-site/pagefind && node scripts/docs-site/pagefind-normalize.mjs",
    "docs:serve": "python3 -m http.server 4173 --bind 127.0.0.1 -d dist/docs-site",
    "docs:smoke": "node scripts/docs-site/smoke.mjs",
    "docs:deploy:dry": "wrangler deploy --config wrangler.docs.toml --dry-run --outdir .wrangler/docs-dry",
    "docs:deploy": "wrangler deploy --config wrangler.docs.toml"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "gray-matter": "4.0.3",
    "highlight.js": "11.11.1",
    "markdown-it": "14.1.1",
    "markdown-it-anchor": "9.2.0",
    "mermaid": "11.15.0",
    "oxfmt": "^0.43.0",
    "oxlint": "1.57.0",
    "pagefind": "1.5.2",
    "svg-pan-zoom": "3.6.2",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "ultracite": "7.4.0",
    "wrangler": "^3.90.0"
  },
  "packageManager": "bun@1.3.13"
}
