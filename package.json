{
  "name": "centraid-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Centraid — personal app builder for desktop, installable web, and mobile clients.",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "typescript": "^5.6.0"
    }
  },
  "scripts": {
    "dev:desktop": "turbo run dev --filter=@centraid/desktop",
    "dev:mobile": "turbo run dev --filter=@centraid/mobile",
    "dev:web": "turbo run dev --filter=@centraid/web",
    "build": "turbo run build",
    "test": "turbo run test",
    "coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . && turbo run lint",
    "lint:types": "bash scripts/lint-types.sh",
    "lint:css": "node scripts/lint-css-classes.mjs",
    "check": "bun run format:check && bun run lint",
    "fix": "ultracite fix",
    "ci": "bun run check && bun run typecheck && bun run lint:types && bun run lint:css",
    "docs:build": "node scripts/docs-site/build.mjs",
    "docs:bundle": "DOCS_SITE_BASE_PATH=/docs node scripts/docs-site/build.mjs && node scripts/docs-site/assemble.mjs",
    "docs:serve": "python3 -m http.server 4173 --bind 127.0.0.1 -d dist/docs-site",
    "docs:smoke": "node scripts/docs-site/smoke.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "astro": "^7.0.6",
    "jsdom": "26.1.0",
    "oxfmt": "^0.43.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "^0.23.0",
    "pagefind": "^1.5.2",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "ultracite": "7.4.0",
    "vitest": "3.2.4"
  },
  "packageManager": "bun@1.3.13"
}
