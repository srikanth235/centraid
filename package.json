{
  "name": "centraid-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Centraid — personal app builder for desktop, installable web, and mobile clients.",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "typescript": "^5.6.0"
    }
  },
  "scripts": {
    "dev:desktop": "turbo run dev --filter=@centraid/desktop",
    "dev:mobile": "turbo run dev --filter=@centraid/mobile",
    "dev:web": "turbo run dev --filter=@centraid/web",
    "build": "turbo run build",
    "test": "turbo run test && node scripts/test-report/report-floors.mjs",
    "coverage": "node scripts/test-report/prepare.mjs --lane vitest && node node_modules/vitest/vitest.mjs run --coverage --reporter=default --reporter=json --outputFile=artifacts/test-results/vitest.json",
    "test:matrix": "node scripts/test-report/validate-matrix.mjs && node scripts/test-report/validate-nightly-wiring.mjs",
    "test:perf": "node scripts/test-report/prepare.mjs --lane perf && node node_modules/vitest/vitest.mjs run --config vitest.perf.config.ts",
    "test:scale": "node scripts/test-report/prepare.mjs --lane scale && node node_modules/vitest/vitest.mjs run --config vitest.scale.config.ts",
    "test:report": "node scripts/test-report/generate.mjs",
    "test:report:smoke": "node scripts/test-report/smoke.mjs",
    "test:quality:nightly": "bun run test:perf && bun run test:scale && bun run test:report",
    "perf:gateway": "turbo run build --filter=@centraid/gateway && bun run --cwd packages/gateway perf:low-end",
    "perf:runtime-probe": "node packages/gateway/scripts/probe-runtime-sqlite.mjs",
    "typecheck": "turbo run typecheck && tsc -p tests",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . && turbo run lint",
    "lint:types": "bash scripts/lint-types.sh",
    "lint:css": "node scripts/lint-css-classes.mjs",
    "lint:e2e-flows": "node scripts/lint-e2e-flows.mjs",
    "lint:packages": "sherif",
    "lint:actions": "actionlint",
    "check": "bun run format:check && bun run lint",
    "fix": "ultracite fix",
    "lint:protocol-routes": "node scripts/lint-protocol-routes.mjs",
    "lint:acp-min-versions": "node scripts/lint-acp-min-versions.mjs",
    "gateway:package:trace": "node scripts/gateway-package/trace.mjs",
    "gateway:package:smoke": "node scripts/gateway-package/smoke.mjs",
    "gateway:package:probe:test": "node --test scripts/gateway-package/probe.test.mjs",
    "gateway:package:assemble": "node scripts/gateway-package/assemble-runtime.mjs",
    "gateway:package:assemble:test": "node --test scripts/gateway-package/assemble-runtime.test.mjs",
    "check:pr": "bun run format:check && bunx oxlint . && bun run lint:packages && bunx turbo run lint && bun run typecheck && bun run lint:types && bun run knip && bun run lint:css && bun run lint:e2e-flows && bun run lint:protocol-routes && bun run lint:acp-min-versions && bun run test:matrix && bun run test:ratchet && bun run test:ratchet:unit && bun run test:affected",
    "check:pr:full": "bun run format:check && bunx oxlint . && bun run lint:packages && bunx turbo run lint && bun run typecheck && bun run lint:types && bun run knip && bun run lint:css && bun run lint:e2e-flows && bun run lint:protocol-routes && bun run lint:acp-min-versions && bun run test:matrix && bun run test:ratchet && bun run test:ratchet:unit && bun run test:affected:full",
    "ci": "bun run check:pr",
    "knip": "knip",
    "docs:build": "node scripts/docs-site/build.mjs",
    "docs:bundle": "DOCS_SITE_BASE_PATH=/docs node scripts/docs-site/build.mjs && node scripts/docs-site/assemble.mjs",
    "docs:serve": "python3 -m http.server 4173 --bind 127.0.0.1 -d dist/docs-site",
    "docs:smoke": "node scripts/docs-site/smoke.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "release:publish": "node scripts/release/publish.mjs",
    "release:classify": "node scripts/release/classify.mjs",
    "release:sync-versions": "node scripts/release/sync-versions.mjs",
    "release:verify-secrets": "node scripts/release/verify-secrets.mjs",
    "release:matrix": "node scripts/release/matrix.mjs",
    "release:surfaces:test": "node --test scripts/release/surfaces.test.mjs",
    "release:restamp": "node scripts/release/restamp-rollout.mjs",
    "boot:smoke": "node scripts/release/boot-smoke.mjs",
    "web:build": "turbo run build --filter=@centraid/web",
    "web:smoke": "node scripts/web/smoke.mjs",
    "lockfile:lint": "node scripts/ci/lockfile-lint.mjs",
    "ci:retry": "node scripts/ci/retry.mjs",
    "test:ratchet": "node scripts/test-report/ratchet-floors.mjs",
    "test:ratchet:unit": "node node_modules/vitest/vitest.mjs run --config scripts/test-report/vitest.config.ts",
    "test:diff-coverage": "node scripts/test-report/diff-coverage.mjs",
    "test:mutation": "node scripts/mutation/run.mjs",
    "test:affected": "turbo run test --filter='[origin/main]' --concurrency=6",
    "test:affected:full": "turbo run test --filter='...[origin/main]' --concurrency=6",
    "test:interop:backup": "bun run --cwd packages/backup test:interop",
    "gateway:npm:pack": "node scripts/gateway-npm/pack.mjs",
    "gateway:npm:pack:dry": "node scripts/gateway-npm/pack.mjs --dry-run",
    "gateway:npm:publish": "node scripts/gateway-npm/publish.mjs",
    "gateway:npm:helpers:test": "node --test scripts/gateway-npm/pack-helpers.test.mjs scripts/gateway-npm/native-platforms.test.mjs",
    "gateway:npm:merge-native": "node scripts/gateway-npm/merge-native-artifacts.mjs",
    "gateway:install": "bash scripts/install-gateway.sh"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.0.1",
    "@stryker-mutator/vitest-runner": "^9.0.1",
    "@vitest/coverage-v8": "3.2.4",
    "astro": "^7.0.6",
    "jsdom": "26.1.0",
    "knip": "^5.66.0",
    "oxfmt": "^0.43.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "^0.23.0",
    "pagefind": "^1.5.2",
    "sherif": "^1.13.0",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "ultracite": "7.4.0",
    "vitest": "3.2.4"
  },
  "packageManager": "bun@1.3.13",
  "op-sqlite": {
    "fts5": true
  }
}
