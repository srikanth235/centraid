{
  "name": "@centraid/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Host-agnostic centraid gateway: wires app-engine + agent-runtime + stores + chat runner against injected paths and secrets. Consumed by the Electron desktop's in-process embed and the standalone `centraid-gateway` daemon.",
  "bin": {
    "centraid-gateway": "./dist/cli/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && rm -rf dist/web && cp -R ../../apps/web/dist dist/web",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/agent-runtime": "workspace:*",
    "@centraid/app-engine": "workspace:*",
    "@centraid/automation": "workspace:*",
    "@centraid/backup": "workspace:*",
    "@centraid/blueprints": "workspace:*",
    "@centraid/skills": "workspace:*",
    "@centraid/tunnel": "workspace:*",
    "@centraid/vault": "workspace:*",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@centraid/web": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
