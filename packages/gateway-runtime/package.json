{
  "name": "@centraid/gateway-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Host-agnostic centraid gateway: wires runtime-core + agent-runtime + stores + chat runner against injected paths and secrets. Consumed by the Electron desktop's in-process embed and the standalone `centraid-gateway` daemon.",
  "bin": {
    "centraid-gateway": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/agent-runtime": "workspace:*",
    "@centraid/runtime-core": "workspace:*"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.13",
    "tar": "^7.4.3",
    "tsx": "^4.20.3",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
