{
  "name": "@centraid/openclaw-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw plugin that mounts a single /centraid prefix on the gateway and dispatches to user-generated apps (static assets + sqlite-backed queries).",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "templates",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/app-engine": "workspace:*",
    "@centraid/automation": "workspace:*",
    "@centraid/stores": "workspace:*",
    "@mariozechner/pi-ai": "^0.73.0",
    "@sinclair/typebox": "^0.27.0"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "openclaw": "^2026.5.7",
    "tsx": "^4.20.3",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "engines": {
    "node": ">=22.5"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  }
}
