{
  "name": "@centraid/app-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Centraid runtime engine — handler loader, sqlite-backed apps, versioned uploads, and the /centraid HTTP surface. Transport-agnostic; consumed by the OpenClaw plugin shim and by the desktop in-process runtime.",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.13",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
