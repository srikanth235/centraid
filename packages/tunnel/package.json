{
  "name": "@centraid/tunnel",
  "version": "0.1.0",
  "private": true,
  "description": "Phone ↔ desktop transport: HTTP tunneled over iroh p2p QUIC (dumbpipe pattern). The desktop accepts connections from a device-key allowlist and forwards tunneled requests to its loopback gateway; the phone runs a localhost proxy so WebView subresources, ES-module imports, and EventSource all ride the pipe with zero gateway HTTP changes (issue #263).",
  "files": [
    "dist",
    "native/*.node",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-native.mjs --release",
    "build:native": "node scripts/build-native.mjs --release",
    "build:native:debug": "node scripts/build-native.mjs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:native": "CENTRAID_RUN_NATIVE_TUNNEL=1 vitest run src/native-relay.test.ts",
    "perf:binding-probe": "node scripts/probe-typed-array.mjs",
    "prepack": "bun run build",
    "clean": "rm -rf dist native/*.node"
  },
  "dependencies": {
    "@number0/iroh": "1.0.0"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
