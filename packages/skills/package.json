{
  "name": "@centraid/skills",
  "version": "0.1.0",
  "private": true,
  "description": "Agent grounding for the centraid app builder, modeled as a skills/ directory of SKILL.md units (model-invocable progressive disclosure) plus the dynamic grounding renderers (live design tokens + host-tool list) that can't be static.",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/agent-runtime": "workspace:*",
    "@centraid/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
