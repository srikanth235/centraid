{
  "manifestVersion": 1,
  "id": "docs",
  "name": "Docs",
  "description": "A drive for your important documents — leases, IDs, warranties, tax forms — as a projection of the vault. Every file's bytes are a sha256-deduped canonical content item; folders are SKOS concepts in the owner's folders scheme, and filing is a single tag per document. Trash sets a purge date about 30 days out and keeps the folder tag, so a restored document lands right back where it was. Uploading, renaming, moving, trashing and folder management all run through typed vault commands — consent-checked and receipted. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.1.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Keeps your important documents filed, downloadable and restorable.",
    "scopes": [
      { "schema": "core", "table": "content_item", "verbs": "read" },
      { "schema": "core", "table": "tag", "verbs": "read" },
      { "schema": "core", "table": "concept", "verbs": "read" },
      { "schema": "core", "table": "concept_scheme", "verbs": "read" },
      { "schema": "core", "table": "add_document", "verbs": "act" },
      { "schema": "core", "table": "rename_document", "verbs": "act" },
      { "schema": "core", "table": "move_document", "verbs": "act" },
      { "schema": "core", "table": "trash_document", "verbs": "act" },
      { "schema": "core", "table": "restore_document", "verbs": "act" },
      { "schema": "core", "table": "create_folder", "verbs": "act" },
      { "schema": "core", "table": "rename_folder", "verbs": "act" },
      { "schema": "core", "table": "delete_folder", "verbs": "act" }
    ]
  },
  "actions": [
    {
      "name": "upload",
      "description": "Add a document through core.add_document; the bytes become a deduped canonical content item filed into a folder (or the drive's top level). Re-uploading identical bytes restores them from trash and renames them.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "data_uri": { "type": "string", "minLength": 6 },
          "title": { "type": "string", "minLength": 1 },
          "folder_id": { "type": "string", "minLength": 1 }
        },
        "required": ["data_uri", "title"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "rename",
      "description": "Rename a document through core.rename_document (refuses trashed documents).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "content_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 }
        },
        "required": ["content_id", "title"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "move",
      "description": "Refile a document into a folder through core.move_document — omit folder_id to move it to the drive's top level.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "content_id": { "type": "string", "minLength": 1 },
          "folder_id": { "type": "string", "minLength": 1 }
        },
        "required": ["content_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "trash",
      "description": "Move a document to the trash through core.trash_document; it keeps its folder and auto-purges about 30 days later. Refused while the bytes are still in use elsewhere in the vault.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "content_id": { "type": "string", "minLength": 1 }
        },
        "required": ["content_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "restore",
      "description": "Bring a document back from the trash through core.restore_document; it returns to the folder it was filed in.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "content_id": { "type": "string", "minLength": 1 }
        },
        "required": ["content_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "create-folder",
      "description": "Create a folder (a SKOS concept in the folders scheme) through core.create_folder; refuses duplicate sibling names.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "parent_folder_id": { "type": "string", "minLength": 1 }
        },
        "required": ["name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "rename-folder",
      "description": "Rename a folder through core.rename_folder (the drive's top level refuses).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "folder_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 }
        },
        "required": ["folder_id", "name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "delete-folder",
      "description": "Delete an empty folder through core.delete_folder — refused while it still holds documents (including trashed ones) or subfolders.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "folder_id": { "type": "string", "minLength": 1 }
        },
        "required": ["folder_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "drive",
      "description": "The whole drive: every folder in the owner's folders scheme and every document (a content item carrying a folders-scheme tag) newest first, trashed ones included with their purge dates.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "folders": { "type": "array" },
          "documents": { "type": "array" },
          "root_folder_id": { "type": ["string", "null"] },
          "vaultDenied": { "type": "object" }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "wide",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#5C677D",
      "options": [
        { "value": "#5C677D", "label": "Slate" },
        { "value": "#4E68DD", "label": "Indigo" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#E55772", "label": "Rose" },
        { "value": "#B47B3F", "label": "Ochre" }
      ]
    }
  ]
}
