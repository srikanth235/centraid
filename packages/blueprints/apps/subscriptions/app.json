{
  "manifestVersion": 1,
  "id": "subscriptions",
  "name": "Subscriptions",
  "description": "Every recurring charge as a projection of the personal vault: subscriptions are finance.recurring_series over your accounts, each normalized to a monthly figure so the running total is honest, and each cadence rolled forward from its anchor date so you see what renews next and what the next 30 days cost. Distinct from Budgets — this answers what renews and what you're bleeding monthly. Add, edit, pause and cancel run through typed finance commands; files (a receipt, a contract) attach per subscription. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.1.0",
  "iconKey": "Coin",
  "colorKey": "ochre",
  "vault": {
    "purpose": "dpv:Billing",
    "why": "Shows what recurring charges you carry and their monthly cost, and lets you add, pause and cancel them.",
    "scopes": [
      { "schema": "finance", "verbs": "read" },
      { "schema": "core", "table": "account", "verbs": "read" },
      { "schema": "core", "table": "party", "verbs": "read" },
      { "schema": "core", "table": "content_item", "verbs": "read" },
      { "schema": "core", "table": "attachment", "verbs": "read" },
      { "schema": "finance", "table": "add_subscription", "verbs": "act" },
      { "schema": "finance", "table": "update_subscription", "verbs": "act" },
      {
        "schema": "finance",
        "table": "set_subscription_status",
        "verbs": "act"
      },
      { "schema": "core", "table": "attach", "verbs": "act" },
      { "schema": "core", "table": "detach", "verbs": "act" }
    ]
  },
  "actions": [
    {
      "name": "add-subscription",
      "description": "Record a recurring charge through finance.add_subscription (account, amount, cadence, optional first/next charge date).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "account_id": { "type": "string", "minLength": 1 },
          "expected_minor": { "type": "integer", "minimum": 1 },
          "rrule": { "type": "string", "minLength": 1 },
          "anchor_on": { "type": "string", "minLength": 1 },
          "counterparty_party_id": { "type": "string", "minLength": 1 },
          "tolerance_pct": { "type": "integer", "minimum": 0, "maximum": 100 }
        },
        "required": ["account_id", "expected_minor", "rrule"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "update-subscription",
      "description": "Edit a subscription in place through finance.update_subscription — price, cadence, next charge date, payee, tolerance; a partial update, only the fields sent change.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "series_id": { "type": "string", "minLength": 1 },
          "expected_minor": { "type": "integer", "minimum": 1 },
          "rrule": { "type": "string", "minLength": 1 },
          "anchor_on": { "type": "string", "minLength": 1 },
          "counterparty_party_id": { "type": "string", "minLength": 1 },
          "tolerance_pct": { "type": "number", "minimum": 0, "maximum": 100 }
        },
        "required": ["series_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "set-status",
      "description": "Pause or cancel a subscription through finance.set_subscription_status.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "series_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["active", "paused", "ended"] }
        },
        "required": ["series_id", "status"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (a receipt, a contract) to a subscription through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": { "type": "string", "minLength": 1 },
          "data_uri": { "type": "string", "minLength": 6 },
          "title": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from a subscription through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": { "type": "string", "minLength": 1 }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "list",
      "description": "Every recurring series joined to its account and counterparty, each amount normalized to a monthly figure, with the active monthly total, attachments, and — for active series with an anchor date — the next renewal date plus a 30-day upcoming-renewals window; plus accounts and parties for the add form.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "subscriptions": { "type": "array" },
          "monthly_active_minor": { "type": "integer" },
          "upcoming": { "type": "array" },
          "accounts": { "type": "array" },
          "parties": { "type": "array" },
          "vaultDenied": { "type": "object" }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#B47B3F",
      "options": [
        { "value": "#B47B3F", "label": "Ochre" },
        { "value": "#4E68DD", "label": "Indigo" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#E55772", "label": "Rose" }
      ]
    }
  ]
}
