{
  "manifestVersion": 1,
  "id": "photos",
  "name": "Photos",
  "description": "Your photo library as a projection of the personal vault: the meaning — assets, albums, capture times — is owned in the vault, while the bytes are rented behind each content item's content_uri. Read-only until the media domain's command pack ships; revoke the grant and the app goes dark.",
  "version": "0.1.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows your photo library and albums.",
    "scopes": [
      { "schema": "media", "verbs": "read" },
      { "schema": "core", "table": "content_item", "verbs": "read" }
    ]
  },
  "actions": [],
  "queries": [
    {
      "name": "library",
      "description": "Every media asset with its content item's content_uri and media_type, plus the albums it belongs to, newest first.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "assets": { "type": "array" },
          "albums": { "type": "array" },
          "vaultDenied": { "type": "object" }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#B47B3F",
      "options": [
        { "value": "#4E68DD", "label": "Indigo" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#E55772", "label": "Rose" },
        { "value": "#B47B3F", "label": "Ochre" }
      ]
    }
  ]
}
