{
  "manifestVersion": 1,
  "id": "studio",
  "name": "Studio",
  "description": "Your client work as a projection of the personal vault: clients are core parties, tracked time is canonical activity, invoices settle against canonical transactions. The whole self-employed loop — client → project → time → invoice → payment — runs through the business domain's typed commands with act consent granted per command; drafting an invoice awaits owner confirmation and sending one always does. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.4.0",
  "iconKey": "Clock",
  "colorKey": "teal",
  "vault": {
    "purpose": "dpv:Billing",
    "why": "Shows and runs your client work: projects, tracked time, and invoices.",
    "scopes": [
      {
        "schema": "business",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "activity",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "transaction",
        "verbs": "read"
      },
      {
        "schema": "business",
        "table": "add_client",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "add_project",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "log_time",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "create_draft_invoice",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "send_invoice",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "mark_invoice_paid",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "add-client",
      "description": "Enroll a party as a client through business.add_client — one client per party.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "status": {
            "type": "string",
            "enum": ["lead", "active", "past"]
          },
          "default_rate_minor": {
            "type": "integer",
            "minimum": 0
          },
          "payment_terms_days": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["party_id", "currency"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "add-project",
      "description": "Open a project under a client through business.add_project — names unique per client.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "active"]
          },
          "starts_on": {
            "type": "string",
            "minLength": 1
          },
          "budget_minor": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["client_id", "name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "log-time",
      "description": "Log a work session through business.log_time — a canonical core.activity decorated with billing state; only active projects accept time.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "started_at": {
            "type": "string",
            "minLength": 1
          },
          "ended_at": {
            "type": "string",
            "minLength": 1
          },
          "billable": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "rate_minor": {
            "type": "integer",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        },
        "required": ["project_id", "started_at", "ended_at"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "create-draft-invoice",
      "description": "Bill selected unbilled entries through business.create_draft_invoice — creates the draft plus lines and marks the entries billed. Risk medium: parks for owner confirmation under the app's default ceiling.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "string",
            "minLength": 1
          },
          "entry_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "due_on": {
            "type": "string",
            "minLength": 1
          },
          "number": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["client_id", "entry_ids", "due_on"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          },
          "invocationId": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "send-invoice",
      "description": "Release a draft invoice through business.send_invoice. Risk high: always parks for the owner — the outward commitment moment.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "invoice_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["invoice_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          },
          "invocationId": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "mark-invoice-paid",
      "description": "Settle a sent/overdue invoice against an existing posted credit through business.mark_invoice_paid — links the ledger, never creates it.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "invoice_id": {
            "type": "string",
            "minLength": 1
          },
          "txn_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["invoice_id", "txn_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          },
          "invocationId": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (signed contract, receipt, any media) to an invoice through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from an invoice through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "studio",
      "description": "Clients (with payment terms), projects with tracked hours and budget progress, unbilled time entries, the recent time-entry timesheet, invoices with due dates and per-line breakdowns, candidate parties for enrollment, and posted credits for settlement — joined across the business schema, core parties, activities, and transactions.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "clients": {
            "type": "array"
          },
          "projects": {
            "type": "array"
          },
          "invoices": {
            "type": "array"
          },
          "unbilled": {
            "type": "array"
          },
          "entries": {
            "type": "array"
          },
          "parties": {
            "type": "array"
          },
          "credits": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#2EA098",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    }
  ]
}
