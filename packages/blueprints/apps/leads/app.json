{
  "manifestVersion": 1,
  "id": "leads",
  "name": "Leads",
  "description": "A lightweight CRM as a projection of the personal vault: leads are business.client rows whose lead \u2192 active \u2192 past lifecycle IS the pipeline. Names come from core.party, running notes from social.contact_card, and files (a proposal, a brief) attach per lead. Prospects are enrolled from the vault's existing people or minted on the spot through core.add_party and enrolled in one flow; creating, enrolling, advancing and noting all run through typed vault commands \u2014 consent-checked and receipted. No data of its own \u2014 revoke the grant and the app goes dark.",
  "version": "0.3.0",
  "vault": {
    "purpose": "dpv:Billing",
    "why": "Shows your prospect pipeline and lets you enrol, advance and note leads.",
    "scopes": [
      {
        "schema": "business",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party_identifier",
        "verbs": "read"
      },
      {
        "schema": "social",
        "table": "contact_card",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "add_party",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "add_client",
        "verbs": "act"
      },
      {
        "schema": "business",
        "table": "update_client",
        "verbs": "act"
      },
      {
        "schema": "social",
        "table": "update_card",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "add-lead",
      "description": "Enrol a party as a new lead through business.add_client (status 'lead').",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "default_rate_minor": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["party_id", "currency"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "add-contact",
      "description": "Create a brand-new contact through core.add_party (with optional email/tel identifiers) and enrol them as a lead through business.add_client in one flow.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string"
          },
          "tel": {
            "type": "string"
          },
          "currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "default_rate_minor": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["display_name", "currency"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          },
          "party_id": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "update-client",
      "description": "Move a lead through the pipeline (lead \u2192 active \u2192 past) or revise its rate through business.update_client.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["lead", "active", "past"]
          },
          "default_rate_minor": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["client_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "save-note",
      "description": "Save a running note on a lead through social.update_card (enrichment on the party's contact card).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        },
        "required": ["party_id", "note"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (a proposal, a brief) to a lead through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from a lead through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "pipeline",
      "description": "A bounded recent window of clients as pipeline cards (lead / active / past; newest by UUIDv7 client_id, default 500) with their names, rates, running notes and attachments, plus the newest unenrolled parties as candidates to add — never a whole-table pull; `truncated` says older leads exist beyond the window.",
      "input": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 20,
            "maximum": 2000
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "leads": {
            "type": "array"
          },
          "candidates": {
            "type": "array"
          },
          "truncated": {
            "type": "boolean"
          },
          "window": {
            "type": "integer"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "search",
      "description": "Full-text lead search through the vault's FTS5 index (party names plus contact-card nickname, org line and running note) — matched parties are joined back to their business.client rows in the pipeline card shape, never a whole-table pull.",
      "input": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          }
        },
        "required": ["term"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "leads": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#E55772",
      "options": [
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    }
  ]
}
