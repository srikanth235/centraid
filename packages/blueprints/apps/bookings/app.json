{
  "manifestVersion": 1,
  "id": "bookings",
  "name": "Bookings",
  "description": "A Calendly-style booking front door as a projection of the personal vault: availability windows are schedule.availability_rule, and each booking is a canonical core.event held for a client. Because an app can't seize your calendar, a booking request PARKS for your confirmation before it holds a slot, and confirming it puts it on the books. Files attach to any booking. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.1.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows your availability and the bookings held on your calendar, and lets you take and confirm requests.",
    "scopes": [
      { "schema": "schedule", "verbs": "read" },
      { "schema": "core", "table": "event", "verbs": "read" },
      { "schema": "core", "table": "party", "verbs": "read" },
      { "schema": "core", "table": "content_item", "verbs": "read" },
      { "schema": "core", "table": "attachment", "verbs": "read" },
      { "schema": "schedule", "table": "set_availability", "verbs": "act" },
      { "schema": "schedule", "table": "request_booking", "verbs": "act" },
      { "schema": "schedule", "table": "confirm_booking", "verbs": "act" },
      { "schema": "core", "table": "attach", "verbs": "act" },
      { "schema": "core", "table": "detach", "verbs": "act" }
    ]
  },
  "actions": [
    {
      "name": "set-availability",
      "description": "Declare a weekly availability window through schedule.set_availability.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "weekday_mask": { "type": "integer", "minimum": 1, "maximum": 127 },
          "window_start": { "type": "string", "minLength": 1 },
          "window_end": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["work", "focus", "personal", "blocked"]
          },
          "tz": { "type": "string", "minLength": 1 }
        },
        "required": ["weekday_mask", "window_start", "window_end", "tz"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "request-booking",
      "description": "Request a slot through schedule.request_booking. Risk high: invoked by an app it parks for the owner, so the returned status is 'parked' with the invocation id.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "calendar_id": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "dtstart": { "type": "string", "minLength": 1 },
          "dtend": { "type": "string", "minLength": 1 },
          "requester_party_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "required": ["calendar_id", "summary", "dtstart", "dtend", "requester_party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" },
          "invocationId": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "confirm-booking",
      "description": "Promote a tentative hold to a confirmed booking through schedule.confirm_booking.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": { "type": "string", "minLength": 1 }
        },
        "required": ["event_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (image, PDF, any media) to a booking through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": { "type": "string", "minLength": 1 },
          "data_uri": { "type": "string", "minLength": 6 },
          "title": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from a booking through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": { "type": "string", "minLength": 1 }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "board",
      "description": "Your availability windows (work and blocked alike, with their kind and tz), and the bookings held on your calendar (tentative = pending your confirmation, confirmed = on the books), each with its client, notes and attachments; plus calendars and parties for the request form.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "availability": { "type": "array" },
          "bookings": { "type": "array" },
          "calendars": { "type": "array" },
          "parties": { "type": "array" },
          "vaultDenied": { "type": "object" }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#4E68DD",
      "options": [
        { "value": "#4E68DD", "label": "Indigo" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#E55772", "label": "Rose" },
        { "value": "#B47B3F", "label": "Ochre" }
      ]
    }
  ]
}
