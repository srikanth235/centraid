{
  "manifestVersion": 1,
  "id": "notes",
  "name": "Notes",
  "description": "A read-only projection of knowledge.note over canonical content: your notes, their notebooks, and their bodies from core.content_item. No actions until the knowledge command pack ships — this app is a window over the vault, not a pen.",
  "version": "0.1.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows your notes and notebooks.",
    "scopes": [
      { "schema": "knowledge", "verbs": "read" },
      { "schema": "core", "table": "content_item", "verbs": "read" }
    ]
  },
  "actions": [],
  "queries": [
    {
      "name": "library",
      "description": "All notes newest first with their notebook names and decoded bodies, plus the notebooks for filtering.",
      "input": { "type": "object", "properties": {}, "additionalProperties": false },
      "output": {
        "type": "object",
        "properties": {
          "notes": { "type": "array" },
          "notebooks": { "type": "array" },
          "vaultDenied": { "type": "object" }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#5C8A4E",
      "options": [
        { "value": "#5C8A4E", "label": "Moss" },
        { "value": "#4E68DD", "label": "Indigo" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#E55772", "label": "Rose" },
        { "value": "#B47B3F", "label": "Ochre" }
      ]
    }
  ]
}
