{
  "manifestVersion": 1,
  "id": "agenda",
  "name": "Agenda",
  "description": "Your calendar as a projection of the personal vault: upcoming events from core.event, proposals, RSVPs and cancellation asks through consent-checked typed commands (cancelling is medium-risk, so it parks for the owner's confirmation). No data of its own — revoke the grant and the app goes dark.",
  "version": "0.5.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows your upcoming schedule and lets you propose, move, and respond to events.",
    "scopes": [
      {
        "schema": "schedule",
        "verbs": "read+act"
      },
      {
        "schema": "schedule",
        "table": "cancel_event",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "event",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "propose",
      "description": "Propose a new event on a calendar (lands tentative; conflicts are refused by the vault's preconditions).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "dtstart": {
            "type": "string",
            "minLength": 1
          },
          "dtend": {
            "type": "string",
            "minLength": 1
          },
          "calendar_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["summary", "dtstart", "dtend", "calendar_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "reschedule",
      "description": "Move an event to a new time (same identity, SEQUENCE bumped).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "dtstart": {
            "type": "string",
            "minLength": 1
          },
          "dtend": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["event_id", "dtstart", "dtend"],
        "additionalProperties": false
      },
      "writes": []
    },
    {
      "name": "rsvp",
      "description": "Record an attendee's response (RFC 5545 PARTSTAT).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "partstat": {
            "type": "string",
            "enum": ["accepted", "declined", "tentative"]
          }
        },
        "required": ["event_id", "party_id", "partstat"],
        "additionalProperties": false
      },
      "writes": []
    },
    {
      "name": "cancel-event",
      "description": "Ask to cancel an event (status → cancelled, SEQUENCE bumped). Cancelling is medium-risk, so the vault parks it for the owner's confirmation instead of executing directly.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["event_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (agenda, invite, any media) to an event through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from an event through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "upcoming",
      "description": "Non-cancelled events, soonest first, with the calendars they could land on and each event's calendar_id. Defaults to today forward; pass ISO `from`/`to` instants to read any visible range (month and week views do), including still-running multi-day events that began before `from`.",
      "input": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array"
          },
          "calendars": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#4E68DD",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    }
  ]
}
