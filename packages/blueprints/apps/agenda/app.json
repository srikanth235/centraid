{
  "manifestVersion": 1,
  "id": "agenda",
  "name": "Agenda",
  "description": "Your calendar as a projection of the personal vault: upcoming events from core.event, proposals, RSVPs and cancellation asks through consent-checked typed commands (cancelling is medium-risk, so it parks for the owner's confirmation). No data of its own — revoke the grant and the app goes dark.",
  "version": "0.5.0",
  "iconKey": "Calendar",
  "colorKey": "indigo",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows your upcoming schedule and lets you propose, move, and respond to events.",
    "scopes": [
      {
        "schema": "schedule",
        "verbs": "read+act"
      },
      {
        "schema": "schedule",
        "table": "cancel_event",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "vault",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "event",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "propose",
      "description": "Propose a new event on a calendar (lands tentative; conflicts are refused by the vault's preconditions). Optional `attendee_party_ids` invite those parties — the command creates needs-action schedule_attendee rows. Optional `rrule` repeats it (RFC 5545 subset: FREQ=DAILY|WEEKLY|MONTHLY|YEARLY with INTERVAL/COUNT/UNTIL/BYDAY); `conferencing_uri` and `reminders` (minutes-before list) ride along on the same call.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "dtstart": {
            "type": "string",
            "minLength": 1
          },
          "dtend": {
            "type": "string",
            "minLength": 1
          },
          "start_tz": {
            "type": "string"
          },
          "calendar_id": {
            "type": "string",
            "minLength": 1
          },
          "attendee_party_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rrule": {
            "type": "string",
            "minLength": 1
          },
          "conferencing_uri": {
            "type": "string",
            "minLength": 1
          },
          "reminders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "minutes_before": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["minutes_before"],
              "additionalProperties": false
            }
          }
        },
        "required": ["summary", "dtstart", "dtend", "calendar_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "reschedule",
      "description": "Move an event to a new time (same identity, SEQUENCE bumped).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "dtstart": {
            "type": "string",
            "minLength": 1
          },
          "dtend": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["event_id", "dtstart", "dtend"],
        "additionalProperties": false
      },
      "writes": []
    },
    {
      "name": "rsvp",
      "description": "Record an attendee's response (RFC 5545 PARTSTAT).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "partstat": {
            "type": "string",
            "enum": ["accepted", "declined", "tentative"]
          }
        },
        "required": ["event_id", "party_id", "partstat"],
        "additionalProperties": false
      },
      "writes": []
    },
    {
      "name": "cancel-event",
      "description": "Ask to cancel an event (status → cancelled, SEQUENCE bumped). Cancelling is medium-risk, so the vault parks it for the owner's confirmation instead of executing directly.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["event_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (agenda, invite, any media) to an event through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "staged_sha": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from an event through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "upcoming",
      "description": "Non-cancelled events, soonest first, with the calendars they could land on, each event's calendar_id, conferencing_uri, its attachments, and its guest list (attendees joined from schedule_attendee → core_party, each `{party_id, name, partstat, is_you}`). Defaults to today forward; pass ISO `from`/`to` instants to read any visible range (month and week views do), including still-running multi-day events that began before `from`. A repeating event (rrule set) is materialized into one row per occurrence inside the visible range — each carries the series' real event_id (reschedule/cancel/RSVP/attach all still target the series), an `instance_key` for list rendering, and `is_recurrence_instance` on every non-anchor occurrence.",
      "input": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array"
          },
          "calendars": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "search",
      "description": "Full-text event search through the vault's FTS5 index (summary + description) — returns only the ranked non-cancelled matches in the upcoming row shape (calendar_id, attachments, and the `attendees` guest list included) plus a hit snippet, never a whole-table pull.",
      "input": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          }
        },
        "required": ["term"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "parties",
      "description": "Pickable people from core.party (kind='person') for the invite picker — each `{party_id, name, is_you}`, you sorted first. `me` is the owner's party id. No event data; just the directory the create-event attendee multi-select draws from.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "parties": {
            "type": "array"
          },
          "me": {
            "type": "string"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#4E68DD",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    },
    {
      "key": "appDefaultView",
      "label": "Default view",
      "type": "segmented",
      "default": "month",
      "options": [
        {
          "value": "month",
          "label": "Month"
        },
        {
          "value": "week",
          "label": "Week"
        },
        {
          "value": "schedule",
          "label": "Schedule"
        }
      ]
    }
  ]
}
