{
  "manifestVersion": 1,
  "id": "people",
  "name": "People",
  "description": "Your circle, remembered — a personal CRM projected from the canonical vault. people_profile keeps only the genuine 1:1 CRM decoration; interactions are core activities, tasks are schedule tasks, relationships are typed core links, IOUs are Tally obligations, and journal entries are knowledge notes. Lists, favorites, notes, important dates, and gift ideas reuse the vault's shared mechanisms too. Every write runs through a typed command — consent-checked and receipted. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.1.1",
  "iconKey": "Users",
  "colorKey": "rose",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Keeps light records on the people you care about and nudges you to stay in touch.",
    "scopes": [
      { "schema": "people", "verbs": "read+act" },
      { "schema": "core", "table": "party", "verbs": "read" },
      { "schema": "core", "table": "vault", "verbs": "read" },
      { "schema": "core", "table": "party_identifier", "verbs": "read" },
      { "schema": "core", "table": "activity", "verbs": "read" },
      { "schema": "core", "table": "link", "verbs": "read" },
      { "schema": "core", "table": "content_item", "verbs": "read" },
      { "schema": "core", "table": "tag", "verbs": "read" },
      { "schema": "core", "table": "concept", "verbs": "read" },
      { "schema": "core", "table": "concept_scheme", "verbs": "read" },
      { "schema": "knowledge", "table": "annotation", "verbs": "read" },
      { "schema": "knowledge", "table": "note", "verbs": "read" },
      { "schema": "schedule", "table": "task", "verbs": "read" },
      { "schema": "tally", "table": "obligation", "verbs": "read" }
    ]
  },
  "actions": [
    {
      "name": "add-person",
      "description": "Add a person to your circle through people.add_person — mints a canonical core.party plus its people_profile, optionally filed into a list. Risk low.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "display_name": { "type": "string", "minLength": 1 },
          "role": { "type": "string" },
          "avatar_color": { "type": "string" },
          "cadence_days": { "type": "integer", "minimum": 1 },
          "list_id": { "type": "string", "minLength": 1 }
        },
        "required": ["display_name", "cadence_days"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "edit-person",
      "description": "Revise a person's name, role line, avatar hue or how-you-met note through people.edit_person.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "role": { "type": "string" },
          "avatar_color": { "type": "string" },
          "met": { "type": "string" }
        },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "set-cadence",
      "description": "Set how often you want to reach out to a person through people.set_cadence.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "cadence_days": { "type": "integer", "minimum": 1 }
        },
        "required": ["party_id", "cadence_days"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "log-interaction",
      "description": "Log a touch (message, call, met up, note) through people.log_interaction; stamps last-contacted so they drop off Reconnect.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "text": { "type": "string" }
        },
        "required": ["party_id", "kind"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "star-person",
      "description": "Favorite a person through people.star_person — the one canonical flags-scheme star, shared across your vault.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "party_id": { "type": "string", "minLength": 1 } },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "unstar-person",
      "description": "Remove a person's favorite star through people.unstar_person.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "party_id": { "type": "string", "minLength": 1 } },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "move-person",
      "description": "Move a person into a list through people.move_person — omit list_id to un-list them.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "list_id": { "type": "string", "minLength": 1 }
        },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-note",
      "description": "Add a note about a person through people.add_note — kept as a searchable annotation on their party.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        },
        "required": ["party_id", "text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-task",
      "description": "Add a follow-up task tied to a person through people.add_task.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        },
        "required": ["party_id", "text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "toggle-task",
      "description": "Toggle a person task between open and done through people.toggle_task.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "task_id": { "type": "string", "minLength": 1 } },
        "required": ["task_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-important-date",
      "description": "Add an important date (birthday, anniversary…) through people.add_important_date; birthdays auto-create their reminder. month_day is MM-DD.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "month_day": { "type": "string", "pattern": "^\\d{2}-\\d{2}$" },
          "reminder_on": { "type": "boolean" }
        },
        "required": ["party_id", "label", "month_day"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "toggle-reminder",
      "description": "Turn a date's reminder on or off through people.toggle_reminder.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "date_id": { "type": "string", "minLength": 1 } },
        "required": ["date_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-relationship",
      "description": "Record a typed core.link to a related canonical party through people.add_relationship; related_party_id reuses an existing party.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "pet": { "type": "string" },
          "related_party_id": { "type": "string", "minLength": 1 }
        },
        "required": ["party_id", "name", "kind"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-gift",
      "description": "Add a gift idea for a person through people.add_gift.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        },
        "required": ["party_id", "text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "toggle-gift",
      "description": "Flip a gift between idea and given through people.toggle_gift.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "gift_id": { "type": "string", "minLength": 1 } },
        "required": ["gift_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-debt",
      "description": "Record a debt you owe a person or they owe you through people.add_debt, in minor units.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": { "type": "string", "minLength": 1 },
          "direction": { "type": "string", "enum": ["owe", "owed"] },
          "amount_minor": { "type": "integer", "minimum": 0 },
          "reason": { "type": "string" }
        },
        "required": ["party_id", "direction", "amount_minor"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "settle-debt",
      "description": "Settle a debt through people.settle_debt (marks it closed, kept as history).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "debt_id": { "type": "string", "minLength": 1 } },
        "required": ["debt_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "create-list",
      "description": "Create a list (a SKOS concept in your lists scheme) through people.create_list, like a Docs folder.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "name": { "type": "string", "minLength": 1 } },
        "required": ["name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "rename-list",
      "description": "Rename a list through people.rename_list.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "list_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 }
        },
        "required": ["list_id", "name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "delete-list",
      "description": "Delete an empty list through people.delete_list (move its people out first).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "list_id": { "type": "string", "minLength": 1 } },
        "required": ["list_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    },
    {
      "name": "add-journal-entry",
      "description": "Add an owner-level journal entry with a mood and a line about your day through people.add_journal_entry.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "mood": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "entry_date": { "type": "string" }
        },
        "required": ["mood", "text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "output": { "type": "object" },
          "reason": { "type": "string" }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "people",
      "description": "The people window as a bounded recent view: people.profile rows (each a 1:1 enrichment of a core.party), newest first, decorated with name, list, favorite star and active reminder dates, plus the lists. `truncated` means older people exist beyond the window.",
      "input": {
        "type": "object",
        "properties": { "limit": { "type": "integer", "minimum": 20, "maximum": 2000 } },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "people": { "type": "array" },
          "lists": { "type": "array" },
          "truncated": { "type": "boolean" },
          "window": { "type": "integer" },
          "vaultDenied": { "type": "object" }
        }
      }
    },
    {
      "name": "person",
      "description": "One person's full profile: name, role, cadence, last-contacted, how-you-met, list, favorite, contact identifiers, relationships, important dates, notes, tasks, gift ideas, open debts and interaction history.",
      "input": {
        "type": "object",
        "properties": { "party_id": { "type": "string", "minLength": 1 } },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "person": { "type": ["object", "null"] },
          "vaultDenied": { "type": "object" }
        }
      }
    },
    {
      "name": "dashboard",
      "description": "The keep-in-touch summary: who is overdue to reconnect with, upcoming reminders (nearest first), recent logged touches, and the headline counts (all / reconnect / upcoming / favorites).",
      "input": { "type": "object", "properties": {}, "additionalProperties": false },
      "output": {
        "type": "object",
        "properties": {
          "reconnect": { "type": "array" },
          "upcoming": { "type": "array" },
          "recent": { "type": "array" },
          "counts": { "type": "object" },
          "vaultDenied": { "type": "object" }
        }
      }
    },
    {
      "name": "journal",
      "description": "The journal newest first: owner entries (mood + a line) folded together with logged interactions as automatic entries.",
      "input": { "type": "object", "properties": {}, "additionalProperties": false },
      "output": {
        "type": "object",
        "properties": {
          "entries": { "type": "array" },
          "vaultDenied": { "type": "object" }
        }
      }
    },
    {
      "name": "search",
      "description": "Full-text people search across three vault FTS5 indexes — the party's name, the role line, and the owner's notes — returning ranked matches in the people row shape plus a hit snippet.",
      "input": {
        "type": "object",
        "properties": { "term": { "type": "string" } },
        "required": ["term"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "people": { "type": "array" },
          "vaultDenied": { "type": "object" }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "wide",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#DD4F6B",
      "options": [
        { "value": "#DD4F6B", "label": "Rose" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#4E68DD", "label": "Indigo" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#C9803A", "label": "Amber" },
        { "value": "#5C677D", "label": "Slate" }
      ]
    },
    {
      "key": "appView",
      "label": "Default view",
      "type": "segmented",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "list", "label": "List" }
      ]
    }
  ]
}
