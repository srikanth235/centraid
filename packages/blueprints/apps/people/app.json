{
  "manifestVersion": 1,
  "id": "people",
  "name": "People",
  "description": "The vault's single identity anchor rendered as a contacts app: every person, org, and agent is a core.party, their handles live in core.party_identifier, and enrichment (nickname, note, favorite) sits in social.contact_card. People are minted through core.add_party and renamed through core.update_party, handles bind through resolve_identity, and composing runs the full draft-then-send lifecycle — sending is risk-high, so it parks for the owner's confirmation. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.4.0",
  "iconKey": "Users",
  "colorKey": "violet",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows the people in your life and keeps their cards current.",
    "scopes": [
      {
        "schema": "social",
        "verbs": "read+act"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party_identifier",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "add_party",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "update_party",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "add-person",
      "description": "Create a new person through core.add_party, binding optional email, tel, or handle identifiers in the same stroke. Risk low; the vault refuses when a handle is already claimed by another party.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string"
          },
          "tel": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          }
        },
        "required": ["display_name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "edit-person",
      "description": "Rename a party or revise its sort name and birth date through core.update_party — identity edits on the party row itself, distinct from contact-card enrichment.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "sort_name": {
            "type": "string"
          },
          "birth_date": {
            "type": "string"
          }
        },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "update-card",
      "description": "Upsert a party's contact card (nickname, note, favorite) through the vault's typed command.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "nickname": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "favorite": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "resolve-identity",
      "description": "Bind an email, tel, or handle to a party through social.resolve_identity — one identity per handle, with retroactive backfill of unresolved thread participants and messages.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "scheme": {
            "type": "string",
            "enum": ["email", "tel", "handle"]
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          }
        },
        "required": ["party_id", "scheme", "value"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "draft-message",
      "description": "Compose a draft to a party through social.draft_message — opens (or reuses) a thread and stores the body as a deduped content item; delivery stays 'draft' until send-message releases it. Risk medium: under the app's default low risk ceiling this parks for owner confirmation too.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "recipient_party_id": {
            "type": "string",
            "minLength": 1
          },
          "body_text": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "enum": ["sms", "email", "dm", "group"]
          },
          "subject": {
            "type": "string"
          }
        },
        "required": ["recipient_party_id", "body_text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "send-message",
      "description": "Release a draft for delivery through social.send_message. Risk-high: invoked by an app it parks for the owner's confirmation, so the returned status is 'parked' with the invocation id, not 'executed'.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["message_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          },
          "invocationId": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (image, PDF, any media) to a person through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from a person through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "directory",
      "description": "A bounded recent window of parties (most recently touched by updated_at, caller-sized) sorted by name within the window, each with its identifiers (scheme + value), contact card, and attachments — never a whole-table pull; `truncated` says more people exist beyond the window.",
      "input": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 20,
            "maximum": 2000
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "people": {
            "type": "array"
          },
          "truncated": {
            "type": "boolean"
          },
          "window": {
            "type": "integer"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "search",
      "description": "Full-text people search through the vault's FTS5 index (party name plus contact-card nickname, org line, and note) — returns only the ranked matches in the directory row shape plus a hit snippet, never a whole-table pull.",
      "input": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          }
        },
        "required": ["term"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "people": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#7C5BD9",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    }
  ]
}
