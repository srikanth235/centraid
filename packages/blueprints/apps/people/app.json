{
  "manifestVersion": 1,
  "id": "people",
  "name": "People",
  "description": "The vault's single identity anchor rendered as a contacts app: every person, org, and agent is a core.party, their handles live in core.party_identifier, and enrichment (nickname, note, favorite) sits in social.contact_card. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.1.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows the people in your life and keeps their cards current.",
    "scopes": [
      {
        "schema": "social",
        "verbs": "read+act"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "party_identifier",
        "verbs": "read"
      }
    ]
  },
  "actions": [
    {
      "name": "update-card",
      "description": "Upsert a party's contact card (nickname, note, favorite) through the vault's typed command.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "party_id": {
            "type": "string",
            "minLength": 1
          },
          "nickname": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "favorite": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["party_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "directory",
      "description": "Every party sorted by display name, each with its identifiers (scheme + value) and contact card if one exists.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "people": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#7C5BD9",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    }
  ]
}
