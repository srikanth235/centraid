{
  "manifestVersion": 1,
  "id": "home-inventory",
  "name": "Home inventory",
  "description": "What you own, where it lives, what it's worth, and what it's covered by — a projection of the vault's home domain. Adding, editing, disposing, covering and marking maintenance done all run through the home domain's typed commands — consent-checked, contract-checked and receipted, with act consent granted per command. Revoke the grant and the app goes dark while the inventory stays the owner's.",
  "version": "0.4.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows your home inventory, warranties, and upcoming maintenance.",
    "scopes": [
      {
        "schema": "home",
        "verbs": "read"
      },
      {
        "schema": "home",
        "table": "add_item",
        "verbs": "act"
      },
      {
        "schema": "home",
        "table": "update_item",
        "verbs": "act"
      },
      {
        "schema": "home",
        "table": "dispose_item",
        "verbs": "act"
      },
      {
        "schema": "home",
        "table": "add_warranty",
        "verbs": "act"
      },
      {
        "schema": "home",
        "table": "complete_maintenance",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "place",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "add-item",
      "description": "Add an owned item through home.add_item; the vault assigns the id. place_id must reference an existing core.place; a purchase price travels in minor units and must name its 3-letter currency.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "acquired_on": {
            "type": "string",
            "minLength": 1
          },
          "serial_no": {
            "type": "string",
            "minLength": 1
          },
          "place_id": {
            "type": "string",
            "minLength": 1
          },
          "purchase_price_minor": {
            "type": "integer",
            "minimum": 0
          },
          "purchase_currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          }
        },
        "required": ["name"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "update-item",
      "description": "Edit an item's name, acquired date, serial, room, or purchase value through home.update_item — partial update, only the fields sent change. place_id must reference an existing core.place; a price set on an item with no recorded currency must name its 3-letter currency.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "acquired_on": {
            "type": "string",
            "minLength": 1
          },
          "serial_no": {
            "type": "string",
            "minLength": 1
          },
          "place_id": {
            "type": "string",
            "minLength": 1
          },
          "purchase_price_minor": {
            "type": "integer",
            "minimum": 0
          },
          "purchase_currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          }
        },
        "required": ["item_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "dispose-item",
      "description": "Dispose an item through home.dispose_item — disposed_on defaults to today, the row is kept so history stays, and a second disposal is refused.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "disposed_on": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["item_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "add-warranty",
      "description": "Record warranty coverage on an item through home.add_warranty (ends_on must be on or after starts_on; claim_uri optional).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "starts_on": {
            "type": "string",
            "minLength": 1
          },
          "ends_on": {
            "type": "string",
            "minLength": 1
          },
          "provider_party_id": {
            "type": "string",
            "minLength": 1
          },
          "claim_uri": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["item_id", "starts_on", "ends_on"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "complete-maintenance",
      "description": "Mark a maintenance plan done through home.complete_maintenance — last_done_on is stamped with done_on and the projected next-due date rolls forward from the plan's rrule. Re-stamping is legitimate: repeating chores are done again and again.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "plan_id": {
            "type": "string",
            "minLength": 1
          },
          "done_on": {
            "type": "string",
            "minLength": 10
          }
        },
        "required": ["plan_id", "done_on"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (photo, warranty, receipt, any media) to an inventory item through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from an inventory item through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "inventory",
      "description": "Owned asset items grouped by place, each with its room, purchase value and warranty history, plus disposed items, maintenance plans with a projected next-due date, and the owner's places for the room picker.",
      "input": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array"
          },
          "disposed": {
            "type": "array"
          },
          "maintenance": {
            "type": "array"
          },
          "places": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#5C677D",
      "options": [
        {
          "value": "#5C677D",
          "label": "Slate"
        },
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        }
      ]
    }
  ]
}
