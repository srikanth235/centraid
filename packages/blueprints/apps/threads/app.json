{
  "manifestVersion": 1,
  "id": "threads",
  "name": "Threads",
  "description": "Your message history as a projection of the personal vault: threads and messages are canonical social rows, bodies are content items. Sending is the consent model's showcase — a send parks until the owner explicitly confirms it. No data of its own — revoke the grant and the app goes dark.",
  "version": "0.4.0",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Reads your message threads and drafts replies; every send waits for your confirmation.",
    "scopes": [
      {
        "schema": "social",
        "verbs": "read+act"
      },
      {
        "schema": "social",
        "table": "mark_thread_read",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "party",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "vault",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "draft",
      "description": "Compose a draft message in an existing thread, or open a new thread with a recipient (the draft never sends by itself).",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "body_text": {
            "type": "string",
            "minLength": 1
          },
          "thread_id": {
            "type": "string",
            "minLength": 1
          },
          "recipient_party_id": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "enum": ["sms", "email", "dm", "group"]
          },
          "subject": {
            "type": "string"
          }
        },
        "required": ["body_text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "send",
      "description": "Release a draft for delivery. Highest-risk command in the model: for an app this parks for the owner's explicit confirmation.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["message_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "mark-read",
      "description": "Stamp the owner's read cursor on a thread (social.mark_thread_read). Silent and idempotent — opening a thread re-marks with a newer instant; the vault inserts a silent owner participant row if the owner never spoke in the thread.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "thread_id": {
            "type": "string",
            "minLength": 1
          },
          "read_at": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["thread_id", "read_at"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Share a file (image, PDF, any media) into a thread through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id", "data_uri"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a shared file from a thread through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "inbox",
      "description": "A bounded recent window of threads (newest by last_message_at, caller-sized via `limit`) with participants' display names, a last-message snippet, a draft flag, an unread flag (owner's read cursor vs the newest inbound message), and a capped recent slice of the party directory for starting new conversations — never a whole-table pull; `truncated` says older threads exist beyond the window (search reaches them).",
      "input": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 20,
            "maximum": 2000
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "threads": {
            "type": "array"
          },
          "parties": {
            "type": "array"
          },
          "truncated": {
            "type": "boolean"
          },
          "window": {
            "type": "integer"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "search",
      "description": "Full-text inbox search through the vault's FTS5 index (message bodies + thread subjects) — returns only the ranked matched threads in the inbox row shape, message hits carrying a hit-marked snippet, never a whole-table pull.",
      "input": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          }
        },
        "required": ["term"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "threads": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "thread",
      "description": "One thread's messages in sent order, bodies decoded from their content items, senders named.",
      "input": {
        "type": "object",
        "properties": {
          "thread_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["thread_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array"
          },
          "attachments": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#4E68DD",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    }
  ]
}
