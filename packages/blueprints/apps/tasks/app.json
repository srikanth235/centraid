{
  "manifestVersion": 1,
  "id": "tasks",
  "name": "Tasks",
  "description": "A Things-style task manager as a projection of the personal vault: canonical tasks from schedule.task, nothing stored here. Adding, completing and editing all run through the schedule domain's typed task commands — consent-checked, contract-checked and receipted. Revoke the grant and the app goes dark while the tasks, history and receipts remain the owner's.",
  "version": "0.3.0",
  "iconKey": "Check",
  "colorKey": "teal",
  "vault": {
    "purpose": "dpv:ServiceProvision",
    "why": "Shows and manages your canonical task list.",
    "scopes": [
      {
        "schema": "schedule",
        "table": "task",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "content_item",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "attachment",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "link",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "link_anchor",
        "verbs": "read"
      },
      {
        "schema": "schedule",
        "table": "add_task",
        "verbs": "act"
      },
      {
        "schema": "schedule",
        "table": "set_task_status",
        "verbs": "act"
      },
      {
        "schema": "schedule",
        "table": "edit_task",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "attach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "detach",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "tag",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "concept",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "concept_scheme",
        "verbs": "read"
      },
      {
        "schema": "core",
        "table": "tag_item",
        "verbs": "act"
      },
      {
        "schema": "core",
        "table": "untag_item",
        "verbs": "act"
      }
    ]
  },
  "actions": [
    {
      "name": "add",
      "description": "Add a task (optionally with a note, dated, prioritized, estimated, repeating, reminded, or as a subtask of a top-level task) through schedule.add_task. A repeating (`rrule`) or reminded (`remind_before_min`) task needs `due_at`.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "due_at": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "effort_min": {
            "type": "integer",
            "minimum": 1
          },
          "parent_task_id": {
            "type": "string",
            "minLength": 1
          },
          "rrule": {
            "type": "string",
            "minLength": 1
          },
          "remind_before_min": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["title"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "set-status",
      "description": "Move a task through the VTODO lifecycle (needs-action, in-process, completed, cancelled) through schedule.set_task_status.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["needs-action", "in-process", "completed", "cancelled"]
          }
        },
        "required": ["task_id", "status"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "edit",
      "description": "Edit a task's title, note (set or clear), due date (set or clear), priority, effort, or reminder lead time (set or clear) through schedule.edit_task.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "clear_description": {
            "type": "boolean"
          },
          "due_at": {
            "type": "string",
            "minLength": 1
          },
          "clear_due": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "effort_min": {
            "type": "integer",
            "minimum": 1
          },
          "remind_before_min": {
            "type": "integer",
            "minimum": 0
          },
          "clear_remind": {
            "type": "boolean"
          },
          "rrule": {
            "type": "string",
            "minLength": 1
          },
          "clear_rrule": {
            "type": "boolean"
          }
        },
        "required": ["task_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "attach",
      "description": "Pin a file (image, PDF, any media) to a task through core.attach; bytes are stored as a deduped canonical content item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string",
            "minLength": 1
          },
          "data_uri": {
            "type": "string",
            "minLength": 6
          },
          "staged_sha": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["photo", "manual", "receipt", "warranty", "contract", "embed", "other"]
          }
        },
        "required": ["subject_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "detach",
      "description": "Remove a file from a task through core.detach; the canonical content item is kept.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "attachment_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["attachment_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "add-tag",
      "description": "Tag a task through core.tag_item — a free-form label shared with every other app that tags through the same command (one shared Tags concept scheme). Idempotent.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["task_id", "label"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    },
    {
      "name": "remove-tag",
      "description": "Remove one tag edge from a task through core.untag_item; the shared concept survives for other subjects.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "tag_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["tag_id"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "output": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "writes": []
    }
  ],
  "queries": [
    {
      "name": "board",
      "description": "The task board as a bounded window (newest open tasks by creation, caller-sized, families kept whole; the logbook read is capped at its visible 50 most recently closed), each row carrying its tags (`[{tag_id, concept_id, label}]`), plus the distinct tag list (`[{concept_id, label}]`) seen within the window — never a whole-table pull; `truncated` says more open tasks exist beyond the window.",
      "input": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 20,
            "maximum": 2000
          }
        },
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "open": {
            "type": "array"
          },
          "logbook": {
            "type": "array"
          },
          "tags": {
            "type": "array"
          },
          "counts": {
            "type": "object"
          },
          "truncated": {
            "type": "boolean"
          },
          "window": {
            "type": "integer"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    },
    {
      "name": "search",
      "description": "Full-text task search through the vault's FTS5 index (title + description) — returns only the ranked matches in the board's per-task row shape plus a hit snippet, never a whole-table pull.",
      "input": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          }
        },
        "required": ["term"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array"
          },
          "vaultDenied": {
            "type": "object"
          }
        }
      }
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        {
          "value": "sans",
          "label": "Sans"
        },
        {
          "value": "serif",
          "label": "Serif"
        },
        {
          "value": "mono",
          "label": "Mono"
        }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#2EA098",
      "options": [
        {
          "value": "#4E68DD",
          "label": "Indigo"
        },
        {
          "value": "#2EA098",
          "label": "Teal"
        },
        {
          "value": "#7C5BD9",
          "label": "Violet"
        },
        {
          "value": "#E55772",
          "label": "Rose"
        },
        {
          "value": "#B47B3F",
          "label": "Ochre"
        }
      ]
    },
    {
      "key": "appDefaultView",
      "label": "Default view",
      "type": "segmented",
      "default": "today",
      "options": [
        {
          "value": "today",
          "label": "Today"
        },
        {
          "value": "upcoming",
          "label": "Upcoming"
        },
        {
          "value": "anytime",
          "label": "Anytime"
        },
        {
          "value": "all",
          "label": "All"
        }
      ]
    }
  ]
}
