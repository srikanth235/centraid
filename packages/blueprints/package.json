{
  "name": "@centraid/blueprints",
  "version": "0.1.0",
  "private": true,
  "description": "How a new centraid app comes into being: blank-app scaffolders, template clone, and the bundled template gallery (pre-built apps + remote-fetch resolver) the desktop offers as clone-and-deploy starting points.",
  "files": [
    "dist",
    "apps",
    "automations",
    "index.json",
    "manifest.json",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build:manifest": "node scripts/build-manifest.mjs",
    "build": "bun run build:manifest && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@centraid/app-engine": "workspace:*",
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
