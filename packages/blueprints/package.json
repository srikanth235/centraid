{
  "name": "@centraid/blueprints",
  "version": "0.1.0",
  "private": false,
  "description": "How a new centraid app comes into being: blank-app scaffolders, template clone, and the bundled template gallery (pre-built apps + remote-fetch resolver) the desktop offers as clone-and-deploy starting points.",
  "license": "SEE LICENSE IN REPOSITORY",
  "files": [
    "dist",
    "apps",
    "automations",
    "kit",
    "index.json",
    "manifest.json",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:manifest": "node scripts/build-manifest.mjs",
    "build": "bun run build:manifest && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun run typecheck:apps",
    "typecheck:apps": "tsc -p tsconfig.apps.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/blob-format": "workspace:*",
    "@centraid/design-tokens": "workspace:*",
    "pdfjs-dist": "5.7.284",
    "tldts": "6.1.86"
  },
  "devDependencies": {
    "@centraid/app-engine": "workspace:*",
    "@centraid/test-kit": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.0",
    "esbuild": "^0.28.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
