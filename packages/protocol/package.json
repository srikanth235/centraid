{
  "name": "@centraid/protocol",
  "version": "0.1.0",
  "private": false,
  "description": "Dependency-free gateway wire types, route constants, version/handshake, and capability map (issue #504).",
  "license": "SEE LICENSE IN REPOSITORY",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@centraid/test-kit": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "catalog:"
  }
}
