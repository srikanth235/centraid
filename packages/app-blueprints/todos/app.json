{
  "manifestVersion": 1,
  "id": "todos",
  "name": "Todos",
  "description": "Capture and clear small things.",
  "version": "0.1.0",
  "tables": [
    {
      "name": "todos",
      "columns": [
        { "name": "id", "type": "INTEGER" },
        { "name": "text", "type": "TEXT" },
        { "name": "done", "type": "INTEGER" },
        { "name": "created_at", "type": "INTEGER" }
      ]
    }
  ],
  "actions": [
    {
      "name": "add",
      "description": "Add a new todo item.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "text": { "type": "string", "minLength": 1 } },
        "required": ["text"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "text": { "type": "string" },
          "done": { "type": "boolean" },
          "createdAt": { "type": "number" }
        }
      },
      "writes": ["todos"]
    },
    {
      "name": "toggle",
      "description": "Flip a todo's done bit.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": { "id": { "type": "number", "minimum": 1 } },
        "required": ["id"],
        "additionalProperties": false
      },
      "writes": ["todos"]
    },
    {
      "name": "delete",
      "description": "Delete a todo by id.",
      "confirmation": "required",
      "input": {
        "type": "object",
        "properties": { "id": { "type": "number", "minimum": 1 } },
        "required": ["id"],
        "additionalProperties": false
      },
      "writes": ["todos"]
    }
  ],
  "queries": [
    {
      "name": "list",
      "description": "All todos, open first then by most-recently created.",
      "input": { "type": "object", "properties": {}, "additionalProperties": false },
      "output": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "number" },
            "text": { "type": "string" },
            "done": { "type": "boolean" },
            "createdAt": { "type": "number" }
          }
        }
      },
      "reads": ["todos"]
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "sans",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "narrow",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appRadius",
      "label": "Corners",
      "type": "segmented",
      "default": "rounded",
      "options": [
        { "value": "sharp", "label": "Sharp" },
        { "value": "rounded", "label": "Rounded" },
        { "value": "pill", "label": "Pill" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#7C5BD9",
      "options": [
        { "value": "#4950F6", "label": "Blue" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#B47B3F", "label": "Ochre" },
        { "value": "#E55772", "label": "Rose" }
      ]
    }
  ]
}
