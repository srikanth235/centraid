{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "outDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["queries/**/*.ts", "actions/**/*.ts", "crons/**/*.ts"]
}
