{
  "manifestVersion": 1,
  "id": "journal",
  "name": "Journal",
  "description": "A clean place to write each day.",
  "version": "0.1.0",
  "tables": [
    {
      "name": "journal_entries",
      "columns": [
        { "name": "date", "type": "TEXT" },
        { "name": "body", "type": "TEXT" },
        { "name": "updated_at", "type": "INTEGER" }
      ]
    }
  ],
  "actions": [
    {
      "name": "save",
      "description": "Upsert the journal entry for a given date.",
      "confirmation": "none",
      "input": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "body": { "type": "string" }
        },
        "required": ["date", "body"],
        "additionalProperties": false
      },
      "output": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "updatedAt": { "type": "number" }
        }
      },
      "writes": ["journal_entries"]
    },
    {
      "name": "delete",
      "description": "Delete the journal entry for a given date.",
      "confirmation": "required",
      "input": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "required": ["date"],
        "additionalProperties": false
      },
      "writes": ["journal_entries"]
    }
  ],
  "queries": [
    {
      "name": "get",
      "description": "Return a single journal entry by date.",
      "input": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "required": ["date"],
        "additionalProperties": false
      },
      "reads": ["journal_entries"]
    },
    {
      "name": "list-dates",
      "description": "All saved entries with a short preview, newest first.",
      "input": { "type": "object", "properties": {}, "additionalProperties": false },
      "output": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "date": { "type": "string" },
            "preview": { "type": "string" }
          }
        }
      },
      "reads": ["journal_entries"]
    }
  ],
  "knobs": [
    {
      "key": "appFont",
      "label": "Font",
      "type": "segmented",
      "default": "serif",
      "options": [
        { "value": "sans", "label": "Sans" },
        { "value": "serif", "label": "Serif" },
        { "value": "mono", "label": "Mono" }
      ]
    },
    {
      "key": "appWidth",
      "label": "Width",
      "type": "segmented",
      "default": "wide",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "key": "appRadius",
      "label": "Corners",
      "type": "segmented",
      "default": "rounded",
      "options": [
        { "value": "sharp", "label": "Sharp" },
        { "value": "rounded", "label": "Rounded" },
        { "value": "pill", "label": "Pill" }
      ]
    },
    {
      "key": "appColor",
      "label": "Color",
      "type": "swatch",
      "default": "#B47B3F",
      "options": [
        { "value": "#4950F6", "label": "Blue" },
        { "value": "#7C5BD9", "label": "Violet" },
        { "value": "#2EA098", "label": "Teal" },
        { "value": "#B47B3F", "label": "Ochre" },
        { "value": "#E55772", "label": "Rose" }
      ]
    }
  ]
}
