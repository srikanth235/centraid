{
  "name": "@centraid/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Unified local agent runtime for centraid: drives one turn over the Agent Client Protocol for every runner kind, launching first-party ACP adapters for CLIs that lack an ACP mode. Used by both the per-app data chat and the builder. Ships a tiny `centraid` CLI bin agents shell out to.",
  "bin": {
    "centraid": "./dist/cli/centraid-cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.60.0",
    "@agentclientprotocol/codex-acp": "1.1.4",
    "@centraid/app-engine": "workspace:*",
    "@centraid/automation": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
