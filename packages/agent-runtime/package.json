{
  "name": "@centraid/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Unified local agent runtime for centraid: drives one turn through either codex app-server (JSON-RPC subprocess) or @anthropic-ai/claude-agent-sdk (in-process). Used by both the per-app data chat and the builder. Ships a tiny `centraid` CLI bin agents shell out to.",
  "bin": {
    "centraid": "./dist/centraid-cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143",
    "@centraid/app-engine": "workspace:*",
    "@centraid/automation": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.3",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
