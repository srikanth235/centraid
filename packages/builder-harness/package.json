{
  "name": "@centraid/builder-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Drives the centraid app BUILDER: an agent session (codex app-server or Claude SDK via @centraid/local-chat-runner) that authors apps in the @centraid/openclaw-plugin format, plus scaffold + publish + gateway HTTP helpers. (For the in-app data chat see @centraid/chat-harness.)",
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/design-tokens": "workspace:*",
    "@centraid/local-chat-runner": "workspace:*",
    "@centraid/openclaw-plugin": "workspace:*",
    "@centraid/runtime-core": "workspace:*",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.13",
    "tsx": "^4.20.3",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
