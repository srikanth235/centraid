{
  "name": "@centraid/ui-core",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-neutral UI logic (classnames, view-models) shared by the desktop React shell and the mobile RN app. No React, no DOM — pure TS on top of @centraid/design-tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "typescript": "catalog:"
  }
}
