{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@centraid/design-tokens": ["../design-tokens/src/index.ts"],
      // Blueprint inline-app entries resolve to a contract stub so tsc never
      // type-checks their .tsx sources under the client program (issue #505).
      "@centraid/blueprints/apps/*/app-inline": [
        "./src/react/blueprints/inline-app-module-stub.d.ts"
      ],
      "@centraid/blueprints/apps/tasks/queries/*": [
        "./src/react/blueprints/inline-query-stub.d.ts"
      ],
      "@centraid/blueprints/apps/agenda/queries/*": [
        "./src/react/blueprints/inline-query-stub.d.ts"
      ],
      "@centraid/blueprints/apps/docs/queries/*": ["./src/react/blueprints/inline-query-stub.d.ts"],
      "@centraid/blueprints/apps/locker/queries/*": [
        "./src/react/blueprints/inline-query-stub.d.ts"
      ],
      "@centraid/blueprints/apps/notes/queries/*": [
        "./src/react/blueprints/inline-query-stub.d.ts"
      ],
      "@centraid/blueprints/apps/people/queries/*": [
        "./src/react/blueprints/inline-query-stub.d.ts"
      ],
      "@centraid/blueprints/apps/photos/queries/*": [
        "./src/react/blueprints/inline-query-stub.d.ts"
      ],
      "@centraid/blueprints/apps/tally/queries/*": ["./src/react/blueprints/inline-query-stub.d.ts"]
    },
    "noUncheckedIndexedAccess": false,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
