  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.13",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.5"
  }
}
