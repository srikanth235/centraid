{
  "name": "@centraid/agent-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-coding-agent customization for centraid: agent that knows how to author apps in the @centraid/openclaw-plugin format, plus scaffold + publish helpers.",
