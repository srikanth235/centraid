.design-sync/ds-src/previews/
.design-sync/ds-src/manifest.json

# Per-app scratch trees the boot harness builds (app.js + symlinked kit assets);
# they must live inside the package because vite refuses to load a dynamically
# imported module from outside the project root. See src/app-boot-harness.ts.
packages/blueprints/.app-boot/
# Built from the lockfile-pinned pdfjs-dist package by
# packages/blueprints/scripts/vendor-pdfjs.mjs. Package build/test regenerate
# both; they are deliberately not opaque checked-in vendor blobs.
packages/blueprints/kit/pdf.min.mjs
packages/blueprints/kit/pdf.worker.min.mjs
# Browser ESM generated from canonical workspace sources by
# packages/blueprints/scripts/vendor-browser-shared.mjs.
packages/blueprints/kit/blob-format.js
packages/blueprints/kit/video-frame.js
# issue #325: second design system — the desktop React shell (Icon/Button/
# Logo/AppCard). Generated bundle + the input package's copied-fresh source,
# fonts, and styles (build.mjs regenerates them all from apps/desktop each run).
ds-bundle-desktop/
.design-sync/desktop-src/src/
.design-sync/desktop-src/dist/
.design-sync/desktop-src/fonts/
.design-sync/desktop-src/styles/
# CSS-module carve tooling bookkeeping (class -> local-name maps used only by
# the carve/rewrite scripts, never read by the app or its build).
*.module.css.map.json

# Browser Iroh WASM: the binary is re-committed so clean CI (static typecheck
# builds @centraid/web without a Rust/wasm toolchain) stays green. Regenerate
# with `bun run --cwd apps/web build:iroh` after changing iroh-wasm
# (issue #468 K15 — ensure-iroh still rebuilds if the file is deleted).
