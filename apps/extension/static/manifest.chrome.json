{
  "manifest_version": 3,
  "name": "Centraid Companion",
  "short_name": "Centraid",
  "description": "Pair this browser with Centraid for explicit Locker autofill and web capture.",
  "version": "0.1.0",
  "action": { "default_popup": "popup.html", "default_title": "Centraid Companion" },
  "background": { "service_worker": "worker.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": ["activeTab", "alarms", "contextMenus", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "icons": { "16": "icon-16.png", "32": "icon-32.png", "48": "icon-48.png", "128": "icon-128.png" }
}
