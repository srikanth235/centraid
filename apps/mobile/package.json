    "@expo-google-fonts/geist": "^0.4.1",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/playfair-display": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@op-engineering/op-sqlite": "17.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@shopify/flash-list": "2.0.2",
