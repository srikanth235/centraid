{
  "name": "@centraid/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "bun scripts/check-import-boundaries.ts",
    "generate:theme": "bun scripts/generate-theme.ts",
    "eas:build:ios": "eas build --platform ios --profile preview --non-interactive",
    "eas:build:android": "eas build --platform android --profile preview --non-interactive",
    "eas:submit:ios": "eas submit --platform ios --profile preview --non-interactive --latest",
    "eas:submit:android": "eas submit --platform android --profile preview --non-interactive --latest"
  },
  "dependencies": {
