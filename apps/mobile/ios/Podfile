require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'Centraid' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # Keep every generated pod aligned with the app and extension target.
    # https://github.com/mrousavy/nitro/issues/422#issuecomment-2545988256
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = podfile_properties['ios.deploymentTarget'] || '17.5'
      end
    end

    # op-sqlite vendors a complete SQLite amalgamation and publishes its
    # `cpp/sqlite3.h` as a *public* pod header. CocoaPods therefore puts
    # `${PODS_ROOT}/Headers/Public/op-sqlite` on the HEADER_SEARCH_PATHS of every
    # target in the workspace, including the Centraid app target — so a plain
    # `#include <sqlite3.h>` anywhere in the app resolves to op-sqlite's
    # amalgamation instead of the SDK's libsqlite3 header.
    #
    # That was harmless until expo-updates landed: it stores its update database
    # in the OS SQLite (`import SQLite3` in EXUpdates/Database/*.swift), so the
    # SDK's sqlite3.h and op-sqlite's now reach the same translation unit. They
    # are different SQLite releases with different struct layouts, and Apple's
    # header guard (`_SQLITE3_H_`) does not match the amalgamation's
    # (`SQLITE3_H`), so neither suppresses the other and the compiler emits ~18
    # `redefinition of 'sqlite3_*'` errors.
    #
    # op-sqlite's own sources reach the header through
    # `${PODS_ROOT}/Headers/Private/op-sqlite`, which is searched first and is
    # scoped to the op-sqlite target alone, so dropping the public copy keeps
    # op-sqlite compiling against its bundled SQLite while `<sqlite3.h>` goes
    # back to meaning "the SDK's SQLite" for everyone else. No pod depends on
    # op-sqlite, so nothing else consumes its public headers.
    #
    # This must fail loudly rather than no-op: if a CocoaPods upgrade or an
    # op-sqlite release moves these paths, a silent skip would hand the problem
    # back to CI as the same inscrutable wall of redefinition errors. So we only
    # skip when op-sqlite is genuinely not installed, and otherwise insist the
    # layout is what we expect.
    exists = ->(path) { File.exist?(path) || File.symlink?(path) }
    if installer.pod_targets.any? { |pod_target| pod_target.pod_name == 'op-sqlite' }
      public_sqlite = File.join(installer.sandbox.public_headers.root, 'op-sqlite', 'sqlite3.h')
      private_sqlite = File.join(installer.sandbox.root, 'Headers', 'Private', 'op-sqlite', 'sqlite3.h')
      unless exists.call(public_sqlite)
        raise "op-sqlite is installed but #{public_sqlite} is missing. The pod's header " \
              'layout changed; re-check whether its bundled sqlite3.h still shadows the ' \
              "SDK's <sqlite3.h> before deleting this hook."
      end
      unless exists.call(private_sqlite)
        raise "op-sqlite has no private sqlite3.h at #{private_sqlite}; refusing to " \
              'unpublish the public copy, as op-sqlite would then compile against the SDK.'
      end
      File.delete(public_sqlite)
      Pod::UI.puts '[centraid] unpublished op-sqlite/sqlite3.h so it cannot shadow the SDK <sqlite3.h>'
    end

  end
end
