{
  "extends": "@centraid/tsconfig/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": [],
    "noEmit": true
  },
  "include": ["src/renderer/react/**/*.tsx", "src/renderer/react/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
