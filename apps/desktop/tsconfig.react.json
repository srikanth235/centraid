{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": [],
    "noEmit": true
  },
  "include": [
    "../../packages/client/src/**/*.tsx",
    "../../packages/client/src/**/*.ts",
    "../../packages/client/src/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
