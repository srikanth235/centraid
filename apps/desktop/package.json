{
  "name": "@centraid/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Centraid desktop — Electron shell + renderer (vanilla TS, migrating to React per #325). Consumes @centraid/design-tokens.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun run build:ts && bun run build:preload && bun run build:assets && bun run build:react",
    "build:ts": "tsc -p tsconfig.json",
    "build:preload": "bun build src/preload.ts --target=node --format=cjs --external electron --outfile dist/preload.cjs",
    "build:assets": "mkdir -p dist/renderer && cp ../../packages/client/src/index.html ../../packages/client/src/styles.css dist/renderer/",
    "build:react": "vite build",
    "dev": "bun run build && electron .",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.react.json --noEmit",
    "test": "vitest run",
    "test:e2e": "node ../../scripts/test-report/prepare.mjs --lane desktop-playwright && bun run build && playwright test -c tests/e2e/playwright.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centraid/agent-runtime": "workspace:*",
    "@centraid/app-engine": "workspace:*",
    "@centraid/automation": "workspace:*",
    "@centraid/client": "workspace:*",
    "@centraid/design-tokens": "workspace:*",
    "@centraid/gateway": "workspace:*",
    "@centraid/tunnel": "workspace:*",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@centraid/tsconfig": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "typescript": "catalog:",
    "vite": "^7.0.0"
  }
}
