#!/usr/bin/env bash
# governance-kit:managed kit-version=0.12.0
# Governance pre-commit hook — generated by governance-bootstrap.
#
# Escape hatches:
#   SKIP_GOVERNANCE=1 git commit ...    # telegraphs intent; CI still enforces
#   git commit --no-verify              # skips all hooks

set -u

if [[ "${SKIP_GOVERNANCE:-0}" == "1" ]]; then
    echo "⊘ governance pre-commit skipped (SKIP_GOVERNANCE=1)" >&2
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
GOVERNANCE_DIR="$ROOT/.governance"

directive_field() {
    local manifest="$1" field="$2"
    [[ -f "$manifest" ]] || return 0
    awk -v k="$field" '
        /^[[:space:]]*#/ { next }
        $0 ~ "^[[:space:]]*" k ":[[:space:]]*" {
            line = $0
            sub(/^[[:space:]]*[^:]+:[[:space:]]*/, "", line)
            sub(/[[:space:]]+#.*$/, "", line)
            sub(/^[[:space:]]+/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line ~ /^".*"$/ || line ~ /^'\''.*'\''$/) {
                line = substr(line, 2, length(line) - 2)
            }
            print line
            exit
        }
    ' "$manifest"
}

directive_dirs_for_hook() {
    local kind="$1" mode="$2"
    local dir hook helper
    [[ -d "$GOVERNANCE_DIR" ]] || return 0
    while IFS= read -r dir; do
        [[ -d "$dir" && -f "$dir/directive.yaml" ]] || continue
        hook="$(directive_field "$dir/directive.yaml" hook)"
        helper="$dir/hooks/$kind.sh"
        case "$mode" in
            helper)
                [[ -x "$helper" ]] && printf '%s\n' "$dir"
                ;;
            check)
                [[ "$hook" == "$kind" && -x "$dir/check.sh" ]] && printf '%s\n' "$dir"
                ;;
        esac
    done < <(
        [[ -d "$GOVERNANCE_DIR/packs" ]] && find "$GOVERNANCE_DIR/packs" -type d -path '*/directives/*' | sort
    )
}
if [[ -x "$ROOT/scripts/test.sh" ]]; then
    bash "$ROOT/scripts/test.sh" || exit 1
elif [[ -x "$ROOT/scripts/test-packs.sh" ]]; then
    bash "$ROOT/scripts/test-packs.sh" || exit 1
fi

while IFS= read -r dir; do
    [[ -z "$dir" ]] && continue
    bash "$dir/hooks/pre-commit.sh" || exit 1
done < <(directive_dirs_for_hook pre-commit helper)

# Sub-agent attestation orchestration (issue #325). Directives declaring a
# `subagent:` block register any pending attestation into a shared ledger as
# their check.sh runs; after the loop we emit ONE grouped remediation
# instruction (shared-batched + isolated). Guarded so an older lib.sh is a no-op.
ATTEST_LEDGER=""
if [[ -f "$GOVERNANCE_DIR/lib.sh" ]]; then
    # shellcheck disable=SC1091
    source "$GOVERNANCE_DIR/lib.sh"
    if declare -F attestation_remediation >/dev/null 2>&1; then
        ATTEST_LEDGER="$(mktemp)"
        export GOVERNANCE_ATTEST_LEDGER="$ATTEST_LEDGER"
        trap 'rm -f "$ATTEST_LEDGER"' EXIT
    fi
fi

fail=0
while IFS= read -r dir; do
    [[ -z "$dir" ]] && continue
    bash "$dir/check.sh" || fail=1
done < <(directive_dirs_for_hook pre-commit check)

[[ -n "$ATTEST_LEDGER" ]] && attestation_remediation "$ATTEST_LEDGER"

if [[ $fail -ne 0 ]]; then
    cat >&2 <<EOF

────────────────────────────────────────
✗ Commit blocked by governance.

Fix the violations above, or bypass (CI will still enforce):
    SKIP_GOVERNANCE=1 git commit ...
    git commit --no-verify
────────────────────────────────────────
EOF
    exit 1
fi

exit 0
