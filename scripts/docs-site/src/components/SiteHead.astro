---
const { current = 'home' } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const hrefFor = (path = '') => `${base}${path}`;
const nav = [
  ['start', 'start'],
  ['data', 'data'],
  ['apps', 'apps'],
  ['devices', 'devices'],
  ['ontology', 'ontology'],
];
---

<header class="site-head">
  <div class="head-row">
    <a class="brand" href={hrefFor()}>
      <span class="mark" aria-hidden="true"
        ><img src={hrefFor('assets/centraid-mark.svg')} alt="" /></span
      >
      Centraid <span class="docs-tag">docs</span>
    </a>
    <nav>
      {
        nav.map(([slug, label]) => (
          <a
            href={hrefFor(`${slug}/`)}
            aria-current={current === slug ? 'page' : undefined}
            class={slug === 'ontology' ? 'hide-sm' : undefined}
          >
            {label}
          </a>
        ))
      }
      <a
        href="https://github.com/srikanth235/centraid"
        target="_blank"
        rel="noopener"
        class="hide-sm">github</a
      >
      <button class="toggle" id="theme-toggle" aria-label="Toggle theme"></button>
    </nav>
  </div>
</header>
