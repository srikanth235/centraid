---
import DocsLayout from '../layouts/DocsLayout.astro';
import content from '../content/understand.html?raw';

const rail = [
  {
    "href": "#pillars",
    "no": "§01",
    "label": "The three pillars",
    "current": true
  },
  {
    "href": "#ontology",
    "no": "§02",
    "label": "The ontology",
    "current": false
  },
  {
    "href": "#index",
    "no": "§03",
    "label": "Find a subsystem",
    "current": false
  }
];
const footer = {
  "manifesto": "Start wide, then go as deep as you like. <em>Every subsystem has exactly one home.</em>",
  "links": [
    {
      "href": "../start/",
      "label": "start",
      "external": false
    },
    {
      "href": "../data/",
      "label": "data",
      "external": false
    },
    {
      "href": "../apps/",
      "label": "apps",
      "external": false
    },
    {
      "href": "../devices/",
      "label": "devices",
      "external": false
    }
  ]
};
---

<DocsLayout
  title="How Centraid Works: Vault, Apps, and Devices"
  description="Understand Centraid's architecture: a private data vault, generated app projections, peer-to-peer devices, and the personal ontology tying them together."
  current="understand"
  canonicalPath="understand/"
  searchLabel="Understand"
  searchKeywords="architecture overview vault gateway grant ontology app projection device tunnel"
  bodyClass="has-rail"
  rail={rail}
  footer={footer}
>
  <Fragment set:html={content} />
</DocsLayout>
