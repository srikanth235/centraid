];
const footer = {
  "manifesto": "The apps are disposable. The devices are replaceable. <em>The vault is the asset.</em>",
  "links": [
    {
      "href": "https://centraid.dev",
      "label": "centraid.dev",
      "external": false
    },
    {
      "href": "../start/",
      "label": "start",
