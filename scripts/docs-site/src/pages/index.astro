---
import DocsLayout from '../layouts/DocsLayout.astro';
import content from '../content/index.html?raw';

const rail = [];
const footer = {
  "manifesto": "Most software is built for everyone, so none of it fits anyone. <em>Yours can just fit you.</em>",
  "links": [
    {
      "href": "https://centraid.dev",
      "label": "centraid.dev",
      "external": false
    },
    {
      "href": "start/",
      "label": "start",
      "external": false
    },
    {
      "href": "ontology/",
      "label": "ontology",
      "external": false
    }
  ]
};
---

<DocsLayout
  title="Centraid Docs: Local-First Personal App Builder"
  description="Learn Centraid, a local-first personal app builder where one private vault powers agent-built apps across your desktop and phone."
  current="home"
  canonicalPath=""
  searchLabel="Home"
  searchKeywords="local-first personal app builder private vault agent-built apps desktop phone peer-to-peer"
  bodyClass=""
  rail={rail}
  footer={footer}
  pageType="CollectionPage"
>
  <Fragment set:html={content} />
</DocsLayout>
