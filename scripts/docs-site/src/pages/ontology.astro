---
import ontologyBodyRaw from '../content/ontology-body.html?raw';
import ontologyStyle from '../content/ontology-style.css?raw';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const canonical = new URL('ontology/', Astro.site ?? 'https://centraid.dev/docs/').toString();
const ontologyBody = ontologyBodyRaw.replaceAll('__DOCS_BASE__', base);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The ontology — Centraid docs</title>
    <meta
      name="description"
      content="Centraid's personal ontology: a person-owned canonical data model of a whole life. Apps become projections; agents act through consent-checked typed commands."
    />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content="The ontology — Centraid docs" />
    <meta
      property="og:description"
      content="Centraid's personal ontology: a person-owned canonical data model of a whole life."
    />
    <meta property="og:type" content="article" />
    <link rel="icon" href={base + 'assets/centraid-mark.svg'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style set:html={ontologyStyle}></style>
  </head>
  <body>
    <Fragment set:html={ontologyBody} />
  </body>
</html>
