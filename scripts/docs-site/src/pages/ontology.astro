---
import DocsLayout from '../layouts/DocsLayout.astro';
import ontologyBodyRaw from '../content/ontology-body.html?raw';
import ontologyStyle from '../content/ontology-style.css?raw';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const rail = [
  { href: '#hero', no: '§01', label: 'System map', current: true },
  { href: '#map', no: '§02', label: 'Unified entity map', current: false },
  { href: '#schema', no: '§03', label: 'Detailed schema', current: false },
  { href: '#principles', no: '§04', label: 'Modeling principles', current: false },
  { href: '#layers', no: '§05', label: 'Ontology layer stack', current: false },
  { href: '#core', no: '§06', label: 'Canonical core', current: false },
  { href: '#domains', no: '§07', label: 'Domain explorer', current: false },
  { href: '#matrix', no: '§08', label: 'Ownership matrix', current: false },
  { href: '#flow', no: '§09', label: 'Cross-app agent flow', current: false },
  { href: '#gateway', no: '§10', label: 'The gateway', current: false },
  { href: '#rules', no: '§11', label: 'Implementation rules', current: false },
  { href: '#centraid', no: '§12', label: 'Inside the runtime', current: false },
];
const footer = {
  manifesto:
    'Centraid is one personal ontology with many replaceable projections. <em>The model is the asset.</em>',
  links: [
    { href: '../start/', label: 'start', external: false },
    { href: '../data/', label: 'data', external: false },
    { href: '../apps/', label: 'apps', external: false },
    { href: '../devices/', label: 'devices', external: false },
  ],
};
const ontologyBody = ontologyBodyRaw
  .replaceAll('__DOCS_BASE__', base)
  .replace(/<header class="topbar">[\s\S]*?<\/header>\s*/, '')
  .replace(/<nav class="rail"[\s\S]*?<\/nav>\s*/, '')
  .replace(/^\s*<main>\s*/, '')
  .replace(/\s*<\/main>\s*<footer>[\s\S]*?<\/footer>\s*/, '\n');
---

<DocsLayout
  title="The ontology — Centraid docs"
  description="Centraid's personal ontology: a person-owned canonical data model of a whole life. Apps become projections; agents act through consent-checked typed commands."
  current="ontology"
  canonicalPath="ontology/"
  bodyClass="has-rail ontology-page"
  rail={rail}
  footer={footer}
>
  <style slot="head" is:global set:html={ontologyStyle}></style>
  <Fragment set:html={ontologyBody} />
</DocsLayout>
